# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
coverage.xml
htmlcov/
.build/
dist/
site/
.eggs/
*.egg-info/

# =========================
# Notebook / editor artifacts
# =========================
.ipynb_checkpoints/
.vscode/
.idea/

